# ============================================================
# Database (required)
# ============================================================
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host:5432/dbname?sslmode=require

# ============================================================
# Authentication (optional in development)
# ============================================================
# Session signing secret — generate with: openssl rand -hex 32
# Auto-generated in development if not set (sessions won't survive restarts)
# SESSION_SIGNING_SECRET=

# Google OAuth credentials — required for Google sign-in
# In development, use /auth/dev/login instead
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ============================================================
# Redis (optional in development)
# ============================================================
# When not set, in-memory fallbacks are used for rate limiting,
# MCP session storage, and resource subscriptions.
# REDIS_URL=redis://localhost:6379

# ============================================================
# MCP Protocol
# ============================================================
# MCP_SERVER_NAME=template-mcp-server
# MCP_ALLOWED_ORIGINS=http://localhost:3000
# MCP_PROTOCOL_VERSION=2025-11-25
# MCP_ENABLE_UI_EXTENSION=true
# MCP_ENABLE_CLIENT_CREDENTIALS=true
# MCP_ENABLE_ENTERPRISE_AUTH=true
# MCP_CONFORMANCE_MODE=false
# MCP_TOKEN_TTL_SECONDS=3600
# MCP_REFRESH_TOKEN_TTL_SECONDS=2592000

# ============================================================
# Rate Limiting
# ============================================================
# RATE_LIMIT_REGISTER_MAX=10
# RATE_LIMIT_REGISTER_WINDOW_SECONDS=60
# RATE_LIMIT_TOKEN_MAX=30
# RATE_LIMIT_TOKEN_WINDOW_SECONDS=60
# RATE_LIMIT_MCP_MAX=60
# RATE_LIMIT_MCP_WINDOW_SECONDS=60

# ============================================================
# Enterprise Authorization (optional)
# ============================================================
# ENTERPRISE_AUTH_PROVIDER_URL=
# ENTERPRISE_AUTH_TENANT=
# ENTERPRISE_AUTH_AUDIENCE=
# ENTERPRISE_AUTH_CLIENT_ID=
# ENTERPRISE_AUTH_CLIENT_SECRET=
# ENTERPRISE_AUTH_ALLOWED_CLIENT_IDS=

# ============================================================
# Observability
# ============================================================
# METRICS_API_KEY=
# LOG_LEVEL=info

# ============================================================
# Server
# ============================================================
# PORT=3000
# NODE_ENV=development
