# Database (Neon Postgres)
DATABASE_URL=             # Pooled connection string from Neon
DATABASE_URL_UNPOOLED=    # Direct connection string (used for migrations)

# Authentication
BETTER_AUTH_SECRET=       # Random secret, at least 32 characters
BETTER_AUTH_URL=          # Optional; defaults from Railway public domain when deployed
GOOGLE_CLIENT_ID=         # Google OAuth client ID
GOOGLE_CLIENT_SECRET=     # Google OAuth client secret

# Redis (required for session coordination and rate limiting)
REDIS_URL=redis://localhost:6379
RATE_LIMIT_REGISTER_MAX=10
RATE_LIMIT_REGISTER_WINDOW_SECONDS=60
RATE_LIMIT_TOKEN_MAX=30
RATE_LIMIT_TOKEN_WINDOW_SECONDS=60

# MCP
MCP_PROTOCOL_VERSION=2025-11-25
MCP_ALLOWED_ORIGINS=http://localhost:3000
MCP_ENABLE_UI_EXTENSION=true
MCP_ENABLE_CLIENT_CREDENTIALS=true
MCP_ENABLE_ENTERPRISE_AUTH=true
MCP_CONFORMANCE_MODE=false
MCP_TOKEN_TTL_SECONDS=3600           # Access token TTL in seconds
MCP_REFRESH_TOKEN_TTL_SECONDS=2592000 # Refresh token TTL in seconds (default 30 days)

# Enterprise-managed authorization extension (required when MCP_ENABLE_ENTERPRISE_AUTH=true)
ENTERPRISE_AUTH_PROVIDER_URL=
ENTERPRISE_AUTH_TENANT=
ENTERPRISE_AUTH_AUDIENCE=
ENTERPRISE_AUTH_CLIENT_ID=
ENTERPRISE_AUTH_CLIENT_SECRET=
ENTERPRISE_AUTH_ALLOWED_CLIENT_IDS=

# Logging/runtime
LOG_LEVEL=info
NODE_ENV=development

# CI
SKIP_ENV_VALIDATION=      # Set to "true" in CI lint/typecheck/build jobs
