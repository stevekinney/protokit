{
	"$schema": "https://turbo.build/schema.json",
	"ui": "stream",
	"globalEnv": [
		"DATABASE_URL",
		"DATABASE_URL_UNPOOLED",
		"SESSION_SIGNING_SECRET",
		"GOOGLE_CLIENT_ID",
		"GOOGLE_CLIENT_SECRET",
		"SESSION_COOKIE_NAME",
		"SESSION_TIME_TO_LIVE_SECONDS",
		"REDIS_URL",
		"RATE_LIMIT_REGISTER_MAX",
		"RATE_LIMIT_REGISTER_WINDOW_SECONDS",
		"RATE_LIMIT_TOKEN_MAX",
		"RATE_LIMIT_TOKEN_WINDOW_SECONDS",
		"INSTANCE_IDENTIFIER",
		"RAILWAY_REPLICA_ID",
		"RAILWAY_INSTANCE_ID",
		"HOSTNAME",
		"MCP_PROTOCOL_VERSION",
		"MCP_ALLOWED_ORIGINS",
		"MCP_ENABLE_UI_EXTENSION",
		"MCP_ENABLE_CLIENT_CREDENTIALS",
		"MCP_ENABLE_ENTERPRISE_AUTH",
		"MCP_SERVER_NAME",
		"MCP_CONFORMANCE_MODE",
		"ENTERPRISE_AUTH_PROVIDER_URL",
		"ENTERPRISE_AUTH_TENANT",
		"ENTERPRISE_AUTH_AUDIENCE",
		"ENTERPRISE_AUTH_CLIENT_ID",
		"ENTERPRISE_AUTH_CLIENT_SECRET",
		"ENTERPRISE_AUTH_ALLOWED_CLIENT_IDS",
		"MCP_TOKEN_TTL_SECONDS",
		"LOG_LEVEL",
		"NODE_ENV",
		"SKIP_ENV_VALIDATION"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", "build/**"],
			"cache": true
		},
		"dev": {
			"dependsOn": ["^build"],
			"cache": false,
			"persistent": true
		},
		"typecheck": {
			"dependsOn": ["^build"],
			"cache": true
		},
		"lint": {
			"cache": true
		},
		"format": {
			"cache": false
		},
		"test": {
			"dependsOn": ["^build"],
			"cache": true
		},
		"test:end-to-end": {
			"dependsOn": ["build"],
			"cache": false
		},
		"db:generate": {
			"cache": false
		},
		"db:migrate": {
			"cache": false
		},
		"db:validate": {
			"cache": false
		},
		"db:seed": {
			"cache": false
		}
	}
}
