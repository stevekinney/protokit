{
	"name": "protokit",
	"private": true,
	"type": "module",
	"workspaces": [
		"applications/*",
		"packages/*"
	],
	"scripts": {
		"build": "bun turbo build",
		"dev": "bun turbo dev",
		"typecheck": "bun turbo typecheck",
		"lint": "bun turbo lint",
		"format": "bun turbo format",
		"test": "bun turbo test",
		"db:generate": "bun turbo db:generate",
		"db:migrate": "bun turbo db:migrate",
		"db:validate": "bun turbo db:validate",
		"dev:full": "bun scripts/develop.ts",
		"prepare": "husky"
	},
	"devDependencies": {
		"@eslint/js": "^9.21.0",
		"eslint": "^9.21.0",
		"globals": "^16.0.0",
		"husky": "^9.1.7",
		"lint-staged": "^15.4.3",
		"prettier": "^3.5.3",
		"turbo": "^2.4.4",
		"typescript": "^5.7.3",
		"typescript-eslint": "^8.25.0"
	},
	"lint-staged": {
		"*.{js,ts,tsx,json,css,html,md}": [
			"prettier --write"
		],
		"*.{js,ts,tsx}": [
			"eslint --fix"
		]
	},
	"packageManager": "bun@1.3.2",
	"overrides": {
		"zod": "^4.0.0"
	}
}
